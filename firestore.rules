rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Allow anyone to read the registration lock status
    match /settings/app {
      allow read: if true;
      // Only allow locking (setting registrationLocked to true) if it's currently false or doesn't exist
      allow write: if (request.auth != null && (!resource.data.registrationLocked || resource.data.registrationLocked == false));
    }

    // 2. User data: Only owner can access their own subtree
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
